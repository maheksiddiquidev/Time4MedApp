<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/imgMedicine"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="Medicine Icon"
        android:src="@drawable/ic_tablet"
        tools:ignore="HardcodedText"/>

    <!-- Heading -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="Time to take your - Medicine"
        android:textColor="#222222"
        android:textSize="26sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"/>

    <!-- Date & Time -->
    <TextView
        android:id="@+id/tvDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="12 March 2026 - 08:00 AM"
        android:textColor="#555555"
        android:textSize="18sp"
        tools:ignore="HardcodedText"/>

    <!-- Medicine Type -->
    <TextView
        android:id="@+id/tvMedicineType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="50dp"
        android:text="Tablet"
        android:textColor="#777777"
        android:textSize="18sp"
        android:textStyle="italic"
        tools:ignore="HardcodedText"/>

    <!-- TAKE Button -->
    <Button
        android:id="@+id/btnTake"
        android:layout_width="250dp"
        android:layout_height="65dp"
        android:backgroundTint="#4CAF50"
        android:text="TAKE MEDICINE"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/tvDisclaimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="⚠️If not taken within 5 minutes, it will be marked as Missed."
        android:textColor="#888888"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"/>

    <!-- Big Tick -->
    <ImageView
        android:id="@+id/imgSuccess"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="30dp"
        android:visibility="gone"
        android:background="@drawable/circle_background"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:src="@drawable/success_tick"/>

    <TextView
        android:id="@+id/tvTakenMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Medicine Taken"
        android:textColor="#4CAF50"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:ignore="HardcodedText"/>

    <TextView
        android:id="@+id/tvHealthyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Stay Healthy, Stay Fit 💪🏻"
        android:textColor="#555555"
        android:textSize="16sp"
        android:visibility="gone"
        tools:ignore="HardcodedText" />

</LinearLayout>